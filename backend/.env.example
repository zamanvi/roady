# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/roady

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=30d

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15550000000
# Twilio Proxy service SID for call/SMS masking between customer and provider
TWILIO_PROXY_SERVICE_SID=KSxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
# Platform takes 10% — remaining 90% goes to provider's connected account
STRIPE_PLATFORM_FEE_PERCENT=10

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_KEY=change_this_to_a_long_random_secret_for_admin_actions

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5500
